{
  "name": "@jakecoxon/command-buffer",
  "version": "0.0.4",
  "type": "module",
  "description": "A command buffer system for efficient text and graphics rendering",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JakeCoxon/command-buffer.git"
  },
  "bugs": {
    "url": "https://github.com/JakeCoxon/command-buffer/issues"
  },
  "homepage": "https://github.com/JakeCoxon/command-buffer#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc src/index.ts --outDir dist --module ESNext --target ES2020 --moduleResolution Bundler --declaration --declarationMap",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --noEmit",
    "build-font-atlas": "tsx scripts/build-font-atlas.ts"
  },
  "peerDependencies": {
    "regl": "^2.1.0",
    "fontkit": "^2.0.2"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.8",
    "@napi-rs/canvas": "^0.1.94",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee",
  "pnpm": {
    "overrides": {}
  }
}
